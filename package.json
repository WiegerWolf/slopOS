{
  "name": "slopos-prototype",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"bun run --cwd apps/bridge dev\" \"bun run --cwd apps/shell dev\"",
    "build": "bun run --cwd apps/shell build",
    "typecheck": "bun run --cwd apps/shell typecheck"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "concurrently": "^9.1.2"
  }
}
